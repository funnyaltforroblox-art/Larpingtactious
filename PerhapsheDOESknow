injectAssetId = function(id, tierName, isSilentRestore)
	local targetFolder = TargetPresetFolder:FindFirstChild(tierName)
	if not targetFolder then return false end
	
	local success, assetModel = pcall(function() return game:GetObjects("rbxassetid://" .. id)[1] end)
	if success and assetModel then
		assetModel.Name = "Asset_" .. tostring(id)
		assetModel.Parent = targetFolder
		if not table.find(AssetIdsToLoad[tierName], id) then table.insert(AssetIdsToLoad[tierName], id) end
		initializeItemData(tierName, assetModel)
		
		if not isSilentRestore then
			selectedItemName = assetModel.Name; selectedSubPartName = "Handle"
			if isPreviewingMode then runUpdatePreviewCycle() elseif LocalPlayer.Character then applyPreset(LocalPlayer.Character, lastPreset) end
			updateItemUI(); updateEditorUI(); saveProfileData()
		end
		return true
	end
	return false
end

