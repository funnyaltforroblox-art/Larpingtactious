local inputs = {}
local function createMatrixInput(labelText, property, orderingIndex)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(1, 0, 0, 24)
	container.BackgroundTransparency = 1
	container.LayoutOrder = orderingIndex
	container.Parent = EditorScroll

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0, 70, 1, 0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamSemibold
	label.Text = labelText
	label.TextColor3 = Color3.fromRGB(170, 170, 180)
	label.TextSize = 11
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = container

	local textBox = Instance.new("TextBox")
	textBox.Size = UDim2.new(1, -75, 1, 0)
	textBox.Position = UDim2.new(0, 75, 0, 0)
	textBox.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
	textBox.BorderSizePixel = 0
	textBox.Font = Enum.Font.Gotham
	textBox.Text = "0"
	textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
	textBox.TextSize = 11
	textBox.ClearTextOnFocus = false
	
	local boxCorner = Instance.new("UICorner")
	boxCorner.CornerRadius = UDim.new(0, 4)
	boxCorner.Parent = textBox
	textBox.Parent = container

	textBox.FocusLost:Connect(function()
		if selectedItemName == "" then return end
		local tierData = CustomOffsets[selectedTierName]
		if tierData and tierData[selectedItemName] and tierData[selectedItemName][selectedSubPartName] then
			local val = tonumber(textBox.Text)
			if val then
				tierData[selectedItemName][selectedSubPartName][property] = val
				if isPreviewingMode then
					runUpdatePreviewCycle()
				elseif LocalPlayer.Character then
					applyPreset(LocalPlayer.Character, lastPreset)
				end
				saveProfileData()
			end
		end
	end)
	inputs[property] = textBox
end

