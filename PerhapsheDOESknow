-- Slot Loading Logic (The Fix)
local function loadSlot(slotKey)
	local slotData = SaveSlots[slotKey]
	if not slotData or slotData.Empty then
		CustomOffsets, AssetIdsToLoad, ExtractedNamesToLoad, ExtractedVisuals = {}, {}, {}, {}
	else
		CustomOffsets = deepCopyTable(slotData.Offsets)
		AssetIdsToLoad = deepCopyTable(slotData.AssetIds)
		ExtractedNamesToLoad = deepCopyTable(slotData.ExtractedNames)
		ExtractedVisuals = deepCopyTable(slotData.ExtractedVisuals)
	end
	
	TargetPresetFolder:ClearAllChildren()
	for t, ids in pairs(AssetIdsToLoad) do for _, id in ipairs(ids) do injectAssetId(id, t) end end
	for t, names in pairs(ExtractedNamesToLoad) do for _, name in ipairs(names) do generateExtractedPlaceholderModel(t, name) end end
end

-- Extraction Logic (The Fix for Mirroring)
local function performExtraction()
	local char = LocalPlayer.Character
	local targetFolder = TargetPresetFolder:FindFirstChild(selectedTierName)
	if not char or not targetFolder then return end

	for _, child in ipairs(char:GetChildren()) do
		if child:IsA("Accessory") then
			local uniqueName = child.Name .. "_" .. tick() -- Forces unique ID so no items mirror
			local cloneCopy = child:Clone()
			cloneCopy.Name = uniqueName
			cloneCopy.Parent = targetFolder
			
			if not ExtractedVisuals[selectedTierName] then ExtractedVisuals[selectedTierName] = {} end
			ExtractedVisuals[selectedTierName][uniqueName] = {}
			
			for _, part in ipairs(cloneCopy:GetDescendants()) do
				if part:IsA("BasePart") then
					local mesh = part:FindFirstChildWhichIsA("SpecialMesh")
					ExtractedVisuals[selectedTierName][uniqueName][part.Name] = {
						MeshId = mesh and mesh.MeshId or "", TextureId = mesh and mesh.TextureId or "",
						SizeX = part.Size.X, SizeY = part.Size.Y, SizeZ = part.Size.Z,
						Transparency = part.Transparency,
						ColorR = part.Color.R * 255, ColorG = part.Color.G * 255, ColorB = part.Color.B * 255
					}
				end
			end
			table.insert(ExtractedNamesToLoad[selectedTierName], uniqueName)
		end
	end
	saveProfileData()
end

