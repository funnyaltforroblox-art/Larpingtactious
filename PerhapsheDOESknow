local function localAttach(character, tierName, item)
	local head = character:WaitForChild("Head", 5)
	if not head then return end
	
	local itemData = CustomOffsets[tierName] and CustomOffsets[tierName][item.Name]
	if not itemData then return end
	
	local clone = item:Clone()
	local handle = clone.Name == "Handle" and clone or clone:FindFirstChild("Handle") or clone:FindFirstChildWhichIsA("BasePart", true)
	if not handle then return end
	handle.Name = "Handle"
	
	for _, child in ipairs(clone:GetDescendants()) do
		if child:IsA("Weld") or child:IsA("ManualWeld") or child:IsA("WeldConstraint") or child:IsA("Attachment") or child:IsA("RigidConstraint") then
			child:Destroy()
		end
	end
	
	local structuralOffsets = {}
	for _, obj in ipairs(clone:GetDescendants()) do
		if obj:IsA("BasePart") and obj ~= handle then
			structuralOffsets[obj.Name] = handle.CFrame:ToObjectSpace(obj.CFrame)
			obj.Anchored = false; obj.CanCollide = false; obj.Massless = true
			local pData = itemData[obj.Name]
			if pData then
				local mesh = obj:FindFirstChildWhichIsA("SpecialMesh")
				if mesh then mesh.Scale = Vector3.new(pData.scaleX or 1, pData.scaleY or 1, pData.scaleZ or 1) else obj.Size = Vector3.new(pData.scaleX or 1, pData.scaleY or 1, pData.scaleZ or 1) end
			end
		end
	end
	
	handle.Anchored = false; handle.CanCollide = false; handle.Massless = true
	local rootData = itemData["Handle"] or {offsetX=0,offsetY=0,offsetZ=0,rotateX=0,rotateY=0,rotateZ=0,scaleX=1,scaleY=1,scaleZ=1}
	local rootMesh = handle:FindFirstChildWhichIsA("SpecialMesh")
	if rootMesh then rootMesh.Scale = Vector3.new(rootData.scaleX or 1, rootData.scaleY or 1, rootData.scaleZ or 1) else handle.Size = Vector3.new(rootData.scaleX or 1, rootData.scaleY or 1, rootData.scaleZ or 1) end

	for _, obj in ipairs(clone:GetDescendants()) do
		if obj:IsA("BasePart") and obj ~= handle then
			local pData = itemData[obj.Name] or {offsetX=0,offsetY=0,offsetZ=0,rotateX=0,rotateY=0,rotateZ=0}
			local innerWeld = Instance.new("Weld", obj)
			innerWeld.Name = "ModelInnerWeld"
			innerWeld.Part0 = obj; innerWeld.Part1 = handle
			innerWeld.C0 = (structuralOffsets[obj.Name] or CFrame.new()):Inverse() * CFrame.new(pData.offsetX or 0, pData.offsetY or 0, pData.offsetZ or 0) * CFrame.Angles(math.rad(pData.rotateX or 0), math.rad(pData.rotateY or 0), math.rad(pData.rotateZ or 0))
		end
	end

	local accessory = clone:IsA("Accessory") and clone or Instance.new("Accessory")
	if not clone:IsA("Accessory") then accessory.Name = item.Name; clone.Parent = accessory else accessory.Name = item.Name end
	
	local rootWeld = Instance.new("Weld", handle)
	rootWeld.Name = "AccessoryWeld"
	rootWeld.Part0 = head; rootWeld.Part1 = handle
	rootWeld.C0 = CFrame.new(rootData.offsetX or 0, rootData.offsetY or 0, rootData.offsetZ or 0) * CFrame.Angles(math.rad(rootData.rotateX or 0), math.rad(rootData.rotateY or 0), math.rad(rootData.rotateZ or 0))
	
	accessory.Parent = character
	table.insert(activeClientInstances, accessory)
end

local function clearActiveItems()
