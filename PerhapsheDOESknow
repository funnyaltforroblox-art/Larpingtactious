local function deepCopyTable(original)
	local copy = {}
	for k, v in pairs(original) do
		if type(v) == "table" then copy[k] = deepCopyTable(v) else copy[k] = v end
	end
	return copy
end

local function saveProfileData()
	if writefile then
		local package = {Offsets=CustomOffsets, AssetIds=AssetIdsToLoad, ExtractedNames=ExtractedNamesToLoad, ExtractedVisuals=ExtractedVisuals, Slots=SaveSlots, SlotNames=SlotNames}
		writefile(FILE_NAME, HttpService:JSONEncode(package))
	end
end

local function loadProfileData()
	if readfile and isfile and isfile(FILE_NAME) then
		local success, parsed = pcall(function() return HttpService:JSONDecode(readfile(FILE_NAME)) end)
		if success and type(parsed) == "table" then
			CustomOffsets = parsed.Offsets or {}; AssetIdsToLoad = parsed.AssetIds or {}
			ExtractedNamesToLoad = parsed.ExtractedNames or {}; ExtractedVisuals = parsed.ExtractedVisuals or {}
			SaveSlots = parsed.Slots or {}; SlotNames = parsed.SlotNames or {}
		end
	end
end
loadProfileData()

local TargetPresetFolder = ReplicatedStorage:FindFirstChild("FaceAccPresets") or Instance.new("Folder", ReplicatedStorage)
TargetPresetFolder.Name = "FaceAccPresets"

local function injectAssetId(id, tierName)
	local targetFolder = TargetPresetFolder:FindFirstChild(tierName)
	if not targetFolder then return end
	local success, assetModel = pcall(function() return game:GetObjects("rbxassetid://" .. id)[1] end)
	if success and assetModel then
		assetModel.Name = "Asset_" .. tostring(id)
		assetModel.Parent = targetFolder
		if not AssetIdsToLoad[tierName] then AssetIdsToLoad[tierName] = {} end
		table.insert(AssetIdsToLoad[tierName], id)
	end
end

local function generateExtractedPlaceholderModel(tierName, itemName)
	local folder = TargetPresetFolder:FindFirstChild(tierName)
	if not folder then return end
	local visualProfile = ExtractedVisuals[tierName] and ExtractedVisuals[tierName][itemName]
	if not visualProfile then return end
	local fakeAccessory = Instance.new("Accessory")
	fakeAccessory.Name = itemName
	for partName, v in pairs(visualProfile) do
		local part = Instance.new("Part", fakeAccessory)
		part.Name = partName
		part.Size = Vector3.new(v.SizeX, v.SizeY, v.SizeZ)
		part.Transparency = v.Transparency
		part.Color = Color3.fromRGB(v.ColorR, v.ColorG, v.ColorB)
		if v.MeshId ~= "" then
			local sm = Instance.new("SpecialMesh", part)
			sm.MeshId = v.MeshId; sm.TextureId = v.TextureId
		end
	end
	fakeAccessory.Parent = folder
end

