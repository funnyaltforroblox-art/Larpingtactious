		rBtn.Text = pName
		rBtn.Font = Enum.Font.Gotham
		rBtn.TextSize = 10
		rBtn.Parent = compDropdownScroll
		
		rBtn.Activated:Connect(function()
			selectedSubPartName = pName
			dropDownWrapper.Visible = false
			updateEditorUI()
			highlightSelectedSubPart()
		end)
	end
	compDropdownScroll.CanvasSize = UDim2.new(0, 0, 0, #sorted * 22)
	
	local pData = itemProfile[selectedSubPartName]
	if pData then
		inputs["offsetX"].Text = tostring(pData.offsetX or 0)
		inputs["offsetY"].Text = tostring(pData.offsetY or 0)
		inputs["offsetZ"].Text = tostring(pData.offsetZ or 0)
		inputs["rotateX"].Text = tostring(pData.rotateX or 0)
		inputs["rotateY"].Text = tostring(pData.rotateY or 0)
		inputs["rotateZ"].Text = tostring(pData.rotateZ or 0)
		inputs["scaleX"].Text  = tostring(pData.scaleX or 1)
		inputs["scaleY"].Text  = tostring(pData.scaleY or 1)
		inputs["scaleZ"].Text  = tostring(pData.scaleZ or 1)
	end
end

