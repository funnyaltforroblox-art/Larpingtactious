-- FEX Customizer - Clean Extraction Build
repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer

local FILE_NAME = "FEX_Customizer_Clean.json"
local TargetPresetFolder = ReplicatedStorage:FindFirstChild("FaceAccPresets") or Instance.new("Folder", ReplicatedStorage)
TargetPresetFolder.Name = "FaceAccPresets"

local CustomOffsets, ExtractedNamesToLoad, ExtractedVisuals, SaveSlots = {}, {}, {}, {}

-- Helper: Deep Copy to prevent memory reference leakage
local function deepCopyTable(original)
    local copy = {}
    for k, v in pairs(original) do
        if type(v) == "table" then copy[k] = deepCopyTable(v) else copy[k] = v end
    end
    return copy
end

local function saveProfileData()
    if writefile then
        local package = {Offsets = CustomOffsets, ExtractedNames = ExtractedNamesToLoad, ExtractedVisuals = ExtractedVisuals, Slots = SaveSlots}
        writefile(FILE_NAME, HttpService:JSONEncode(package))
    end
end

-- Extraction Logic: Uses tick() to ensure unique keys for every accessory
local function extractAccessory(accessory, tierName)
    local handle = accessory:FindFirstChild("Handle") or accessory:FindFirstChildWhichIsA("BasePart", true)
    if not handle then return end
    
    -- Unique Key: Ensures even if you extract the same item twice, it isn't mirrored
    local uniqueID = accessory.Name .. "_" .. tostring(tick())
    
    if not ExtractedVisuals[tierName] then ExtractedVisuals[tierName] = {} end
    ExtractedVisuals[tierName][uniqueID] = {}
    
    -- Extract Visual Data
    for _, part in ipairs(accessory:GetDescendants()) do
        if part:IsA("BasePart") then
            local pMesh = part:FindFirstChildWhichIsA("SpecialMesh")
            ExtractedVisuals[tierName][uniqueID][part.Name] = {
                MeshId = pMesh and pMesh.MeshId or "",
                TextureId = pMesh and pMesh.TextureId or "",
                Size = part.Size,
                Transparency = part.Transparency,
                Color = {part.Color.R, part.Color.G, part.Color.B}
            }
        end
    end
    
    table.insert(ExtractedNamesToLoad[tierName], uniqueID)
    return uniqueID
end

-- UI Setup (Simplified for Reliability)
local ScreenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 400, 0, 200)
MainFrame.Position = UDim2.new(0.5, -200, 0.5, -100)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.Visible = true

local ExtractBtn = Instance.new("TextButton", MainFrame)
ExtractBtn.Size = UDim2.new(0, 200, 0, 50)
ExtractBtn.Position = UDim2.new(0.5, -100, 0.5, -25)
ExtractBtn.Text = "EXTRACT ALL ACCESSORIES"

ExtractBtn.Activated:Connect(function()
    local char = LocalPlayer.Character
    for _, child in ipairs(char:GetChildren()) do
        if child:IsA("Accessory") then
            extractAccessory(child, "Default")
        end
    end
    saveProfileData()
    print("Extraction Complete. Data saved to " .. FILE_NAME)
end)
