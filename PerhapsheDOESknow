local FILE_NAME = "FEX_Customizer_Full_Data.json"
local Config = {
	SelectedDefault = "face acc", SelectedMinor = "MinorDamage",
	SelectedMedium = "MediumDamage", SelectedMajor = "MajorDamage", SelectedCritical = "CriticalDamage"
}

local CustomOffsets, AssetIdsToLoad, ExtractedNamesToLoad, ExtractedVisuals = {}, {}, {}, {}
