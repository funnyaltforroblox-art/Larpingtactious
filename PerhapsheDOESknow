local function drawSaveSlotsInterface()
	for _, child in ipairs(SlotFramePanel:GetChildren()) do
		if child:IsA("Frame") then child:Destroy() end
	end
	
	for i = 1, 5 do
		local slotKey = tostring(i)
		local slotData = SaveSlots[slotKey]
		local isEmpty = slotData.Empty == true
		
		local card = Instance.new("Frame")
