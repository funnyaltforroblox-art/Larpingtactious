local function applyPreset(character, folderName)
	clearActiveItems()
	if folderName == "" or folderName == "None" then return end
	local folder = TargetPresetFolder:FindFirstChild(folderName)
	if not folder then return end
	for _, item in ipairs(folder:GetChildren()) do task.spawn(localAttach, character, folderName, item) end
	task.defer(highlightSelectedSubPart)
end

local function forceRecalculateHealthPreset(character)
	if isPreviewingMode then return end 
	local humanoid = character:FindFirstChild("Humanoid")
	if not humanoid then return end
	local ratio = humanoid.Health / humanoid.MaxHealth
	local target = Config.SelectedDefault
	if ratio <= 0.15 then target = Config.SelectedCritical
	elseif ratio <= 0.30 then target = Config.SelectedMajor
	elseif ratio <= 0.50 then target = Config.SelectedMedium
	elseif ratio <= 0.75 then target = Config.SelectedMinor end
	if target ~= lastPreset then lastPreset = target; applyPreset(character, target) end
end

local function monitorHealth(character)
	character:WaitForChild("Humanoid").HealthChanged:Connect(function() forceRecalculateHealthPreset(character) end)
	forceRecalculateHealthPreset(character)
end

-- PURE OBJECT REHYDRATOR: Completely bypasses IDs and rebuilds raw configurations perfectly
local function generateExtractedPlaceholderModel(tierName, itemName)
	local folder = TargetPresetFolder:FindFirstChild(tierName)
	if not folder or folder:FindFirstChild(itemName) then return end
	
	local visualProfile = ExtractedVisuals[tierName] and ExtractedVisuals[tierName][itemName]
	if not visualProfile then return end
	
	local fakeAccessory = Instance.new("Accessory")
	fakeAccessory.Name = itemName
	
	for partName, visualData in pairs(visualProfile) do
		local part = Instance.new("Part", fakeAccessory)
		part.Name = partName
		part.Size = Vector3.new(visualData.SizeX or 1, visualData.SizeY or 1, visualData.SizeZ or 1)
		part.Transparency = visualData.Transparency or 0
		part.Color = Color3.fromRGB(visualData.ColorR or 255, visualData.ColorG or 255, visualData.ColorB or 255)
		
		if visualData.MeshId and visualData.MeshId ~= "" then
			local sm = Instance.new("SpecialMesh", part)
			sm.MeshId = visualData.MeshId
			sm.TextureId = visualData.TextureId or ""
			sm.Scale = Vector3.new(1, 1, 1)
		end
	end
	fakeAccessory.Parent = folder
end

