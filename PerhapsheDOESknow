local ExtractBtn = Instance.new("TextButton", EditorScroll)
ExtractBtn.Size = UDim2.new(1, 0, 0, 30)
ExtractBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 150)
ExtractBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ExtractBtn.Text = "EXTRACT ACCESSORIES"
ExtractBtn.Font = Enum.Font.GothamBold
ExtractBtn.TextSize = 11
ExtractBtn.LayoutOrder = 50 
Instance.new("UICorner", ExtractBtn).CornerRadius = UDim.new(0, 4)

ExtractBtn.Activated:Connect(function()
	local char = LocalPlayer.Character
	if not char or not char:FindFirstChild("Head") then return end
	local head = char.Head
	local targetFolder = TargetPresetFolder:FindFirstChild(selectedTierName)
	if not targetFolder then return end

	local extractedCount = 0
	for _, child in ipairs(char:GetChildren()) do
		if child:IsA("Accessory") and not table.find(activeClientInstances, child) then
			local handle = child:FindFirstChild("Handle") or child:FindFirstChildWhichIsA("BasePart", true)
			if handle and handle:IsA("BasePart") then
				local internalName = child.Name
				local cloneCopy = child:Clone()
				cloneCopy.Name = internalName
				
				for _, subItem in ipairs(cloneCopy:GetDescendants()) do
					if subItem:IsA("Weld") or subItem:IsA("ManualWeld") or subItem:IsA("WeldConstraint") or subItem:IsA("Attachment") or subItem:IsA("RigidConstraint") then subItem:Destroy() end
				end
				cloneCopy.Parent = targetFolder
				
				if not ExtractedVisuals[selectedTierName] then ExtractedVisuals[selectedTierName] = {} end
				ExtractedVisuals[selectedTierName][internalName] = {}
				
				-- SERIALIZATION LOGIC: Deep records exact looks so Roblox IDs are no longer needed
				for _, part in ipairs(cloneCopy:GetDescendants()) do
					if part:IsA("BasePart") then
						local pMesh = part:FindFirstChildWhichIsA("SpecialMesh")
						ExtractedVisuals[selectedTierName][internalName][part.Name] = {
							MeshId = pMesh and pMesh.MeshId or "",
							TextureId = pMesh and pMesh.TextureId or "",
							SizeX = part.Size.X, SizeY = part.Size.Y, SizeZ = part.Size.Z,
							Transparency = part.Transparency,
							ColorR = math.floor(part.Color.R * 255), ColorG = math.floor(part.Color.G * 255), ColorB = math.floor(part.Color.B * 255)
						}
					end
				end
				
				if not table.find(ExtractedNamesToLoad[selectedTierName], internalName) then
					table.insert(ExtractedNamesToLoad[selectedTierName], internalName)
				end
				
				initializeItemData(selectedTierName, cloneCopy)
				
				local relativeCFrame = head.CFrame:ToObjectSpace(handle.CFrame)
				local rX, rY, rZ = relativeCFrame:ToEulerAnglesXYZ()
				local pMesh = handle:FindFirstChildWhichIsA("SpecialMesh")
				
				if CustomOffsets[selectedTierName] and CustomOffsets[selectedTierName][internalName] then
					CustomOffsets[selectedTierName][internalName]["Handle"] = {
						offsetX = relativeCFrame.X, offsetY = relativeCFrame.Y, offsetZ = relativeCFrame.Z,
						rotateX = math.deg(rX), rotateY = math.deg(rY), rotateZ = math.deg(rZ),
						scaleX = pMesh and pMesh.Scale.X or handle.Size.X,
						scaleY = pMesh and pMesh.Scale.Y or handle.Size.Y,
						scaleZ = pMesh and pMesh.Scale.Z or handle.Size.Z
					}
				end
				extractedCount = extractedCount + 1
			end
		end
	end
	
	saveProfileData(); updateItemUI(); updateEditorUI()
	if isPreviewingMode then runUpdatePreviewCycle() elseif LocalPlayer.Character then applyPreset(LocalPlayer.Character, lastPreset) end
	ExtractBtn.Text = "DONE (" .. tostring(extractedCount) .. ")"; task.wait(1); ExtractBtn.Text = "EXTRACT ACCESSORIES"
end)

updateEditorUI = function()
	if selectedItemName == "" then compSelectBtn.Text = "No Selection"; for _, box in pairs(inputs) do box.Text = "" end; return end
	compSelectBtn.Text = "Part: " .. selectedSubPartName
	compDropdownScroll:ClearAllChildren()
	
	local itemProfile = CustomOffsets[selectedTierName][selectedItemName]
	if not itemProfile then return end
	
	local sorted = {}
	for n, _ in pairs(itemProfile) do table.insert(sorted, n) end
	table.sort(sorted, function(a, b) if a == "Handle" then return true elseif b == "Handle" then return false else return a < b end end)
	
	for _, pName in ipairs(sorted) do
		local rBtn = Instance.new("TextButton", compDropdownScroll)
		rBtn.Size = UDim2.new(1, 0, 0, 22)
		rBtn.BackgroundColor3 = (pName == selectedSubPartName) and Color3.fromRGB(0, 120, 60) or Color3.fromRGB(30, 30, 35)
		rBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		rBtn.Text = pName
		rBtn.Font = Enum.Font.Gotham
		rBtn.TextSize = 10
		rBtn.Activated:Connect(function() selectedSubPartName = pName; dropDownWrapper.Visible = false; updateEditorUI(); highlightSelectedSubPart() end)
	end
	compDropdownScroll.CanvasSize = UDim2.new(0, 0, 0, #sorted * 22)
	
	local pData = itemProfile[selectedSubPartName]
	if pData then
		for prop, box in pairs(inputs) do box.Text = tostring(pData[prop] or (string.find(prop, "scale") and 1 or 0)) end
	end
end

updateItemUI = function()
	ItemSelectionPanel:ClearAllChildren()
	Instance.new("UIListLayout", ItemSelectionPanel).Padding = UDim.new(0, 4)
	local targetFolder = TargetPresetFolder:FindFirstChild(selectedTierName)
