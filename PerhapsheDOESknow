-- Health-Based Face & Model Customizer (Sub-Component Offsets & Uniform Scaling Engine)
repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- ====================================================================
-- COMPONENT DATABASE STRUCTURE (Your Core Customization Layout)
-- ====================================================================
-- Each folder tier now supports multiple custom objects, with unique offsets 
-- for individual Sub-Parts (e.g., Handle, Component_1, etc.)
local Config = {
	SelectedDefault  = "face acc",      -- 100% Health Folder Name
	SelectedMinor    = "MinorDamage",   -- <= 75% Health Folder Name
	SelectedMedium   = "MediumDamage",  -- <= 50% Health Folder Name
	SelectedMajor    = "MajorDamage",   -- <= 30% Health Folder Name
	SelectedCritical = "CriticalDamage" -- <= 15% Health Folder Name
}

-- Central memory database to look up structural edits for specific tier items
-- Format: CustomOffsets[TierName][ItemName][SubPartName] = {offsets...}
local CustomOffsets = {}

local lastPreset = ""
local activeClientInstances = {}

-- ====================================================================
-- DIRECTORY SETUP LAYER
-- ====================================================================
local TargetPresetFolder = ReplicatedStorage:FindFirstChild("FaceAccPresets")
if not TargetPresetFolder then
	local success, result = pcall(function()
		local folder = Instance.new("Folder")
		folder.Name = "FaceAccPresets"
		folder.Parent = ReplicatedStorage
		return folder
	end)
	if success then TargetPresetFolder = result else
		TargetPresetFolder = Instance.new("Folder")
		TargetPresetFolder.Name = "FaceAccPresets"
		TargetPresetFolder.Parent = LocalPlayer:WaitForChild("PlayerGui")
	end
end

local function ensureSubFolder(name)
	if not TargetPresetFolder:FindFirstChild(name) then
		local subFolder = Instance.new("Folder")
		subFolder.Name = name
		subFolder.Parent = TargetPresetFolder
		CustomOffsets[name] = {}
	end
end

ensureSubFolder(Config.SelectedDefault)
ensureSubFolder(Config.SelectedMinor)
ensureSubFolder(Config.SelectedMedium)
ensureSubFolder(Config.SelectedMajor)
ensureSubFolder(Config.SelectedCritical)

-- Helper initialization function to map data schemas to items discovered inside the folders
local function initializeItemData(tierName, item)
	if not CustomOffsets[tierName] then CustomOffsets[tierName] = {} end
	if CustomOffsets[tierName][item.Name] then return end -- Already initialized
	
	local itemProfile = {}
	
	-- Locate primary handles
	local handle = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart", true)
	if not handle and item:IsA("Model") and item.PrimaryPart then handle = item.PrimaryPart end
	
	if handle then
		handle.Name = "Handle"
		itemProfile["Handle"] = {offsetX = 0, offsetY = 0, offsetZ = 0, rotateX = 0, rotateY = 0, rotateZ = 0, scaleX = 1, scaleY = 1, scaleZ = 1}
		
		local partCounter = 1
		for _, child in ipairs(item:GetDescendants()) do
			if child:IsA("BasePart") and child ~= handle then
				if child.Name == "Part" or child.Name == "MeshPart" or child.Name == "" then
					child.Name = "Component_" .. tostring(partCounter)
					partCounter = partCounter + 1
				end
				
				local defaultX, defaultY, defaultZ = 1, 1, 1
				local mesh = child:FindFirstChildWhichIsA("SpecialMesh")
				if mesh then
					defaultX, defaultY, defaultZ = mesh.Scale.X, mesh.Scale.Y, mesh.Scale.Z
				else
					defaultX, defaultY, defaultZ = child.Size.X, child.Size.Y, child.Size.Z
				end
				
				itemProfile[child.Name] = {
					offsetX = 0, offsetY = 0, offsetZ = 0,
					rotateX = 0, rotateY = 0, rotateZ = 0,
					scaleX = defaultX, scaleY = defaultY, scaleZ = defaultZ
				}
			end
		end
	end
	CustomOffsets[tierName][item.Name] = itemProfile
end

-- ====================================================================
-- POSITIONING, SCALING & ATTACHMENT CORE PIPELINE
-- ====================================================================
local function localAttach(character, tierName, item)
	local head = character:WaitForChild("Head", 5)
	if not head then return end
	
	-- Build internal layout data for the source asset first
	initializeItemData(tierName, item)
	local itemData = CustomOffsets[tierName][item.Name]
	
	local clone = item:Clone()
	local handle = clone.Name == "Handle" and clone or clone:FindFirstChild("Handle") or clone:FindFirstChildWhichIsA("BasePart", true)
	if not handle and clone:IsA("Model") and clone.PrimaryPart then handle = clone.PrimaryPart end
	if not handle then return end
	
	handle.Name = "Handle"
	
	-- Clean out game joints inside asset code blocks
	for _, child in ipairs(clone:GetDescendants()) do
		if child:IsA("Weld") or child:IsA("ManualWeld") or child:IsA("WeldConstraint") or child:IsA("Attachment") then
			child:Destroy()
		end
	end
	
	-- 1. Apply scaling and inner sub-weld configurations if model contains components
	local structuralOffsets = {}
	local partCounter = 1
	
	for _, obj in ipairs(clone:GetDescendants()) do
		if obj:IsA("BasePart") and obj ~= handle then
			if obj.Name == "Part" or obj.Name == "MeshPart" or obj.Name == "" then
				obj.Name = "Component_" .. tostring(partCounter)
				partCounter = partCounter + 1
			end
			
			structuralOffsets[obj.Name] = handle.CFrame:ToObjectSpace(obj.CFrame)
			obj.Anchored = false; obj.CanCollide = false; obj.Massless = true
			
			local pData = itemData[obj.Name]
			if pData then
				local mesh = obj:FindFirstChildWhichIsA("SpecialMesh")
				if mesh then
					mesh.Scale = Vector3.new(pData.scaleX, pData.scaleY, pData.scaleZ)
				else
					obj.Size = Vector3.new(pData.scaleX, pData.scaleY, pData.scaleZ)
				end
			end
		end
	end
	
	-- Handle base element adjustments
	handle.Anchored = false; handle.CanCollide = false; handle.Massless = true
	local rootData = itemData["Handle"] or {offsetX=0,offsetY=0,offsetZ=0,rotateX=0,rotateY=0,rotateZ=0,scaleX=1,scaleY=1,scaleZ=1}
	local rootMesh = handle:FindFirstChildWhichIsA("SpecialMesh")
	if rootMesh then
		rootMesh.Scale = Vector3.new(rootData.scaleX, rootData.scaleY, rootData.scaleZ)
	else
		handle.Size = Vector3.new(rootData.scaleX, rootData.scaleY, rootData.scaleZ)
	end

	-- 2. Construct inner structural rigid matrices (Weld mapping)
	for _, obj in ipairs(clone:GetDescendants()) do
		if obj:IsA("BasePart") and obj ~= handle then
			local pData = itemData[obj.Name] or {offsetX=0,offsetY=0,offsetZ=0,rotateX=0,rotateY=0,rotateZ=0}
			local innerWeld = Instance.new("Weld")
			innerWeld.Name = "ModelInnerWeld"
			innerWeld.Part0 = obj
			innerWeld.Part1 = handle
			
			local originalLocalCFrame = structuralOffsets[obj.Name] or CFrame.new()
			local customPosOffset = CFrame.new(pData.offsetX, pData.offsetY, pData.offsetZ)
			local customRotOffset = CFrame.Angles(math.rad(pData.rotateX), math.rad(pData.rotateY), math.rad(pData.rotateZ))
			
			innerWeld.C0 = originalLocalCFrame:Inverse() * (customPosOffset * customRotOffset)
			innerWeld.Parent = obj
		end
	end

	-- 3. Parent to character and apply root attachment weld to Head
	local accessory = clone:IsA("Accessory") and clone or Instance.new("Accessory")
	if not clone:IsA("Accessory") then
		accessory.Name = "CustomAttachedAsset"
		clone.Parent = accessory
	else
		accessory.Name = clone.Name
	end
	
	local rootWeld = Instance.new("Weld")
	rootWeld.Name = "AccessoryWeld"
	rootWeld.Part0 = handle
	rootWeld.Part1 = head
	
	local positionOffset = CFrame.new(rootData.offsetX, rootData.offsetY, rootData.offsetZ)
	local rotationOffset = CFrame.Angles(math.rad(rootData.rotateX), math.rad(rootData.rotateY), math.rad(rootData.rotateZ))
	
	rootWeld.C0 = positionOffset * rotationOffset
	rootWeld.Parent = handle
	
	accessory.Parent = character
	table.insert(activeClientInstances, accessory)
end

local function clearActiveItems()
	for _, item in ipairs(activeClientInstances) do
		if item and item.Parent then item:Destroy() end
	end
	activeClientInstances = {}
end

local function applyPreset(character, folderName)
	clearActiveItems()
	if folderName == "" or folderName == "None" then return end
	
	local folder = TargetPresetFolder:FindFirstChild(folderName)
	if not folder then return end
	
	for _, item in ipairs(folder:GetChildren()) do
		task.spawn(localAttach, character, folderName, item)
	end
end

-- ====================================================================
-- HEALTH DETECTOR MONITOR LOOP
-- ====================================================================
local function monitorHealth(character)
	local human = character:WaitForChild("Humanoid")
	
	local function check()
		local ratio = human.Health / human.MaxHealth
		local target = Config.SelectedDefault
		
		if ratio <= 0.15 then target = Config.SelectedCritical
		elseif ratio <= 0.30 then target = Config.SelectedMajor
		elseif ratio <= 0.50 then target = Config.SelectedMedium
		elseif ratio <= 0.75 then target = Config.SelectedMinor end
		
		if target ~= lastPreset then
			lastPreset = target
			applyPreset(character, target)
		end
	end
	
	human.HealthChanged:Connect(check)
	check()
end

