updateEditorUI = function()
	if selectedItemName == "" then
		compSelectBtn.Text = "No Item Selected"
		for _, box in pairs(inputs) do box.Text = "" end
		return
	end
	
	compSelectBtn.Text = "Part: " .. selectedSubPartName
	compDropdownScroll:ClearAllChildren()
	
	local dropLayout = Instance.new("UIListLayout")
	dropLayout.Parent = compDropdownScroll
	
	local itemProfile = CustomOffsets[selectedTierName][selectedItemName]
	if not itemProfile then return end
	
	local sorted = {}
	for n, _ in pairs(itemProfile) do table.insert(sorted, n) end
	table.sort(sorted, function(a, b) if a == "Handle" then return true elseif b == "Handle" then return false else return a < b end end)
	
	for _, pName in ipairs(sorted) do
		local rBtn = Instance.new("TextButton")
		rBtn.Size = UDim2.new(1, 0, 0, 22)
		rBtn.BackgroundColor3 = (pName == selectedSubPartName) and Color3.fromRGB(0, 120, 60) or Color3.fromRGB(30, 30, 35)
		rBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		rBtn.Text = pName
		rBtn.Font = Enum.Font.Gotham
		rBtn.TextSize = 10
		rBtn.Parent = compDropdownScroll
		
		rBtn.Activated:Connect(function()
			selectedSubPartName = pName
			compDropdownScroll.Visible = false
			updateEditorUI()
			highlightSelectedSubPart()
		end)
	end
	compDropdownScroll.CanvasSize = UDim2.new(0, 0, 0, #sorted * 22)
	
	local pData = itemProfile[selectedSubPartName]
	if pData then
		inputs["offsetX"].Text = tostring(pData.offsetX)
		inputs["offsetY"].Text = tostring(pData.offsetY)
		inputs["offsetZ"].Text = tostring(pData.offsetZ)
		inputs["rotateX"].Text = tostring(pData.rotateX)
		inputs["rotateY"].Text = tostring(pData.rotateY)
		inputs["rotateZ"].Text = tostring(pData.rotateZ)
		inputs["scaleX"].Text  = tostring(pData.scaleX)
		inputs["scaleY"].Text  = tostring(pData.scaleY)
		inputs["scaleZ"].Text  = tostring(pData.scaleZ)
	end
end

updateItemUI = function()
	ItemSelectionPanel:ClearAllChildren()
	local listLayout = Instance.new("UIListLayout")
	listLayout.Padding = UDim.new(0, 4)
	listLayout.Parent = ItemSelectionPanel
	
	local targetFolder = TargetPresetFolder:FindFirstChild(selectedTierName)
	if not targetFolder then return end
	
	local children = targetFolder:GetChildren()
	if #children == 0 then
		selectedItemName = ""
		updateEditorUI()
		return
	end
	
	for _, child in ipairs(children) do
		initializeItemData(selectedTierName, child)
		
		local iBtn = Instance.new("TextButton")
		iBtn.Size = UDim2.new(1, 0, 0, 26)
		iBtn.BackgroundColor3 = (child.Name == selectedItemName) and Color3.fromRGB(0, 90, 160) or Color3.fromRGB(35, 35, 40)
		iBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		iBtn.Text = child.Name
		iBtn.Font = Enum.Font.GothamSemibold
		iBtn.TextSize = 10
		iBtn.Parent = ItemSelectionPanel
		
		iBtn.Activated:Connect(function()
			selectedItemName = child.Name
			selectedSubPartName = "Handle"
			updateItemUI()
			updateEditorUI()
			highlightSelectedSubPart()
		end)
	end
end

updateTierUI = function()
	TierSelectionPanel:ClearAllChildren()
	local listLayout = Instance.new("UIListLayout")
	listLayout.Padding = UDim.new(0, 4)
	listLayout.Parent = TierSelectionPanel
	
	local tiers = {Config.SelectedDefault, Config.SelectedMinor, Config.SelectedMedium, Config.SelectedMajor, Config.SelectedCritical}
	for _, tName in ipairs(tiers) do
		local tBtn = Instance.new("TextButton")
		tBtn.Size = UDim2.new(1, 0, 0, 26)
		tBtn.BackgroundColor3 = (tName == selectedTierName) and Color3.fromRGB(120, 80, 0) or Color3.fromRGB(35, 35, 40)
		tBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		tBtn.Text = tName
		tBtn.Font = Enum.Font.GothamBold
		tBtn.TextSize = 10
		tBtn.Parent = TierSelectionPanel
		
		tBtn.Activated:Connect(function()
			selectedTierName = tName
			selectedItemName = ""
			selectedSubPartName = "Handle"
			updateTierUI()
			updateItemUI()
			updateEditorUI()
			clearActiveHighlight()
		end)
	end
end

updateTierUI()
updateItemUI()
updateEditorUI()

