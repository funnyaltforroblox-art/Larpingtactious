local ExtractBtnCorner = Instance.new("UICorner")
ExtractBtnCorner.CornerRadius = UDim.new(0, 4)
ExtractBtnCorner.Parent = ExtractBtn

ExtractBtn.Activated:Connect(function()
	local char = LocalPlayer.Character
	if not char then return end
	
	local head = char:FindFirstChild("Head")
	if not head then return end
	
	local targetFolder = TargetPresetFolder:FindFirstChild(selectedTierName)
	if not targetFolder then return end

	local extractedCount = 0
	ExtractBtn.Text = "EXTRACTING..."
	ExtractBtn.BackgroundColor3 = Color3.fromRGB(130, 90, 0)
	
	for _, child in ipairs(char:GetChildren()) do
		-- Filter out objects running locally on client layout active engine arrays
		if child:IsA("Accessory") and not table.find(activeClientInstances, child) then
			local handle = child:FindFirstChild("Handle")
			if handle and handle:IsA("BasePart") then
				local assetId = 0
				-- Search for AssetId definitions inside special structural properties
				local mesh = handle:FindFirstChildWhichIsA("SpecialMesh")
				if mesh and mesh.MeshId ~= "" then
					local rawId = string.match(mesh.MeshId, "%d+")
					if rawId then assetId = tonumber(rawId) end
				end
				
				-- Alternate search fallback path via regular structural configuration IDs
				if assetId == 0 and child:FindFirstChildWhichIsA("Script") == nil then
					local rawId = string.match(child.Name, "%d+")
					if rawId then assetId = tonumber(rawId) end
				end

				-- Clone structural asset configurations down to current profile databases
				local internalName = child.Name
				local cloneCopy = child:Clone()
				cloneCopy.Name = internalName
				cloneCopy.Parent = targetFolder
				
				if assetId > 0 and not table.find(AssetIdsToLoad[selectedTierName], assetId) then
					table.insert(AssetIdsToLoad[selectedTierName], assetId)
				end
				
				-- Extract specific matrix values natively bound by welds inside characters
				initializeItemData(selectedTierName, cloneCopy)
				
				local weld = handle:FindFirstChild("AccessoryWeld") or handle:FindFirstChildWhichIsA("Weld")
				local offsetX, offsetY, offsetZ = 0, 0, 0
				local rotX, rotY, rotZ = 0, 0, 0
				local scaleX, scaleY, scaleZ = 1, 1, 1
				
				if weld then
					local c0 = weld.C0
					offsetX, offsetY, offsetZ = c0.X, c0.Y, c0.Z
					local rX, rY, rZ = c0:ToEulerAnglesXYZ()
					-- FIX applied here: math.deg instead of math.degrees
					rotX, rotY, rotZ = math.deg(rX), math.deg(rY), math.deg(rZ)
				end
				
				if mesh then
					scaleX, scaleY, scaleZ = mesh.Scale.X, mesh.Scale.Y, mesh.Scale.Z
				else
					scaleX, scaleY, scaleZ = handle.Size.X, handle.Size.Y, handle.Size.Z
				end
				
				-- Inject the extracted data right into the configuration setup table
				if CustomOffsets[selectedTierName] and CustomOffsets[selectedTierName][internalName] then
					CustomOffsets[selectedTierName][internalName]["Handle"] = {
						offsetX = offsetX, offsetY = offsetY, offsetZ = offsetZ,
						rotateX = rotX, rotateY = rotY, rotateZ = rotZ,
						scaleX = scaleX, scaleY = scaleY, scaleZ = scaleZ
					}
				end
				extractedCount = extractedCount + 1
			end
		end
	end
	
	saveProfileData()
	updateItemUI()
	updateEditorUI()
	
	if isPreviewingMode then
		runUpdatePreviewCycle()
	elseif LocalPlayer.Character then
		applyPreset(LocalPlayer.Character, lastPreset)
	end
	
	ExtractBtn.Text = "EXTRACTED (" .. tostring(extractedCount) .. ")"
	ExtractBtn.BackgroundColor3 = Color3.fromRGB(0, 130, 70)
	task.wait(1.2)
	ExtractBtn.Text = "EXTRACT ACCESSORIES"
	ExtractBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 150)
end)

updateEditorUI = function()
	if selectedItemName == "" then
		compSelectBtn.Text = "No Item Selected"
		for _, box in pairs(inputs) do box.Text = "" end
		return
	end
	
	compSelectBtn.Text = "Part: " .. selectedSubPartName
	compDropdownScroll:ClearAllChildren()
	
	local dropLayout = Instance.new("UIListLayout")
	dropLayout.Parent = compDropdownScroll
	
	local itemProfile = CustomOffsets[selectedTierName][selectedItemName]
	if not itemProfile then return end
	
	local sorted = {}
	for n, _ in pairs(itemProfile) do table.insert(sorted, n) end
	table.sort(sorted, function(a, b) if a == "Handle" then return true elseif b == "Handle" then return false else return a < b end end)
	
	for _, pName in ipairs(sorted) do
		local rBtn = Instance.new("TextButton")
		rBtn.Size = UDim2.new(1, 0, 0, 22)
		rBtn.BackgroundColor3 = (pName == selectedSubPartName) and Color3.fromRGB(0, 120, 60) or Color3.fromRGB(30, 30, 35)
