-- ====================================================================
local function batchRehydrateSavedAssets()
	print("[FEX Restorer]: Parsing structure for saved mesh accessories...")
	local count = 0
	for tierName, idList in pairs(AssetIdsToLoad) do
		for _, id in ipairs(idList) do
			count = count + 1
			task.spawn(function()
				injectAssetId(id, tierName, true)
				-- Refresh UI states progressively as assets background mount
				if tierName == selectedTierName then
					updateItemUI()
					updateEditorUI()
				end
			end)
		end
	end
	print("[FEX Restorer]: Triggered " .. tostring(count) .. " assets for local session generation.")
end

