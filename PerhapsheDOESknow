		card.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
		card.BorderSizePixel = 0
		card.Parent = SlotFramePanel
		
		local cardCorner = Instance.new("UICorner")
		cardCorner.CornerRadius = UDim.new(0, 4)
		cardCorner.Parent = card
		
		local statusLabel = Instance.new("TextLabel")
		statusLabel.Size = UDim2.new(1, -10, 0, 16)
		statusLabel.Position = UDim2.new(0, 6, 0, 2)
		statusLabel.BackgroundTransparency = 1
		statusLabel.Font = Enum.Font.GothamBold
		statusLabel.Text = "SLOT " .. slotKey .. (isEmpty and " [EMPTY]" or " [SAVED]")
		statusLabel.TextColor3 = isEmpty and Color3.fromRGB(130, 130, 140) or Color3.fromRGB(0, 255, 150)
		statusLabel.TextSize = 9
		statusLabel.TextXAlignment = Enum.TextXAlignment.Left
		statusLabel.Parent = card
		
		local loadBtn = Instance.new("TextButton")
		loadBtn.Size = UDim2.new(0, 62, 0, 18)
		loadBtn.Position = UDim2.new(0, 6, 0, 20)
		loadBtn.BackgroundColor3 = isEmpty and Color3.fromRGB(45, 45, 50) or Color3.fromRGB(0, 100, 180)
		loadBtn.Font = Enum.Font.GothamBold
		loadBtn.Text = "LOAD"
		loadBtn.TextColor3 = isEmpty and Color3.fromRGB(160, 160, 160) or Color3.fromRGB(255, 255, 255)
		loadBtn.TextSize = 9
		loadBtn.AutoButtonColor = true
		loadBtn.Parent = card
		
		local lCc = Instance.new("UICorner")
		lCc.CornerRadius = UDim.new(0, 3)
		lCc.Parent = loadBtn
		
		local saveBtn = Instance.new("TextButton")
		saveBtn.Size = UDim2.new(0, 62, 0, 18)
		saveBtn.Position = UDim2.new(0, 76, 0, 20)
		saveBtn.BackgroundColor3 = Color3.fromRGB(150, 90, 0)
		saveBtn.Font = Enum.Font.GothamBold
		saveBtn.Text = "SAVE"
		saveBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		saveBtn.TextSize = 9
		saveBtn.Parent = card
		
		local sCc = Instance.new("UICorner")
		sCc.CornerRadius = UDim.new(0, 3)
		sCc.Parent = saveBtn
		
		-- Direct Overwrite Save Execution Handler
		saveBtn.Activated:Connect(function()
			SaveSlots[slotKey] = {
				Empty = false,
				Offsets = HttpService:JSONDecode(HttpService:JSONEncode(CustomOffsets)),
				AssetIds = HttpService:JSONDecode(HttpService:JSONEncode(AssetIdsToLoad))
			}
			saveProfileData()
			drawSaveSlotsInterface()
			
			for _, element in ipairs(SlotFramePanel:GetChildren()) do
				if element:IsA("Frame") and element:FindFirstChild("SLOT " .. slotKey) then
					local targetSave = element:FindFirstChild("SAVE") or element:FindFirstChildWhichIsA("TextButton")
					if targetSave and targetSave.Position.X.Offset > 50 then
						targetSave.Text = "SAVED!"
						targetSave.BackgroundColor3 = Color3.fromRGB(0, 150, 80)
						task.wait(0.8)
						drawSaveSlotsInterface()
					end
				end
			end
		end)
		
		-- Load action execution mapping
		loadBtn.Activated:Connect(function()
			if isEmpty then
				CustomOffsets = {}
				AssetIdsToLoad = {}
				local tiers = {Config.SelectedDefault, Config.SelectedMinor, Config.SelectedMedium, Config.SelectedMajor, Config.SelectedCritical}
				for _, tName in ipairs(tiers) do
					CustomOffsets[tName] = {}
					AssetIdsToLoad[tName] = {}
				end
			else
				CustomOffsets = HttpService:JSONDecode(HttpService:JSONEncode(slotData.Offsets))
				AssetIdsToLoad = HttpService:JSONDecode(HttpService:JSONEncode(slotData.AssetIds))
			end
			
			for _, folder in ipairs(TargetPresetFolder:GetChildren()) do
				folder:ClearAllChildren()
			end
			
			saveProfileData()
			
			if not isEmpty then
				for tierName, idList in pairs(AssetIdsToLoad) do
					for _, id in ipairs(idList) do
						injectAssetId(id, tierName, true)
					end
				end
				task.wait(0.2)
			else
				selectedItemName = ""
				selectedSubPartName = "Handle"
			end
			
			if isPreviewingMode then
				runUpdatePreviewCycle()
			elseif LocalPlayer.Character then
				lastPreset = ""
				forceRecalculateHealthPreset(LocalPlayer.Character)
			end
			
			updateTierUI()
			updateItemUI()
