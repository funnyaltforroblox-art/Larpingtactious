	label.Parent = EditorScroll

	local textBox = Instance.new("TextBox")
	textBox.Size = UDim2.new(1, -75, 0, 22)
	textBox.Position = UDim2.new(0, 75, 0, yPos)
	textBox.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
	textBox.BorderSizePixel = 0
	textBox.Font = Enum.Font.Gotham
	textBox.Text = "0"
	textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
	textBox.TextSize = 11
	textBox.ClearTextOnFocus = false
	
	local boxCorner = Instance.new("UICorner")
	boxCorner.CornerRadius = UDim.new(0, 4)
	boxCorner.Parent = textBox
	textBox.Parent = EditorScroll

	textBox.FocusLost:Connect(function()
		if selectedItemName == "" then return end
		local tierData = CustomOffsets[selectedTierName]
		if tierData and tierData[selectedItemName] and tierData[selectedItemName][selectedSubPartName] then
			local val = tonumber(textBox.Text)
			if val then
				tierData[selectedItemName][selectedSubPartName][property] = val
				if LocalPlayer.Character then
					applyPreset(LocalPlayer.Character, lastPreset)
				end
			end
		end
	end)
	inputs[property] = textBox
end

