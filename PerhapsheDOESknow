-- ====================================================================
-- SLIDER CREATION ENGINE (RGB & SATURATION)
-- ====================================================================
local sliders = {}
local function createColorSlider(name, color, yPos, min, max)
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -20, 0, 14)
	label.Position = UDim2.new(0, 10, 0, yPos)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.Text = name .. ": " .. tostring(max)
	label.TextColor3 = color
	label.TextSize = 10
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = ColorPanel

	local track = Instance.new("Frame")
	track.Size = UDim2.new(1, -20, 0, 6)
	track.Position = UDim2.new(0, 10, 0, yPos + 16)
	track.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
	track.BorderSizePixel = 0
	track.Parent = ColorPanel
	
	local trackCorner = Instance.new("UICorner")
	trackCorner.CornerRadius = UDim.new(1, 0)
	trackCorner.Parent = track

	local knob = Instance.new("TextButton")
	knob.Size = UDim2.new(0, 12, 0, 12)
	knob.Position = UDim2.new(1, -12, 0.5, -6)
	knob.BackgroundColor3 = color
	knob.Text = ""
	knob.Parent = track
	
	local knobCorner = Instance.new("UICorner")
	knobCorner.CornerRadius = UDim.new(1, 0)
	knobCorner.Parent = knob

	local activeSliding = false
	
	local function updateSliderPosition(inputPosition)
		local relativeX = math.clamp((inputPosition.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		knob.Position = UDim2.new(relativeX, -6, 0.5, -6)
		
		local computedValue = min + (relativeX * (max - min))
		if max > 1 then computedValue = math.floor(computedValue) end
		
		label.Text = name .. ": " .. tostring(computedValue)
		
		if selectedItemName ~= "" then
			local tierData = CustomOffsets[selectedTierName]
			if tierData and tierData[selectedItemName] and tierData[selectedItemName][selectedSubPartName] then
				tierData[selectedItemName][selectedSubPartName][name] = computedValue
				if LocalPlayer.Character then
					applyPreset(LocalPlayer.Character, lastPreset)
				end
			end
		end
	end

	knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			activeSliding = true
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			if activeSliding then
				activeSliding = false
				saveProfileData()
			end
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if activeSliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateSliderPosition(input.Position)
		end
	end)
	
	sliders[name] = {knob = knob, label = label, track = track, min = min, max = max}
end

createColorSlider("colorR", Color3.fromRGB(255, 80, 80), 10, 0, 255)
createColorSlider("colorG", Color3.fromRGB(80, 255, 80), 48, 0, 255)
createColorSlider("colorB", Color3.fromRGB(80, 80, 255), 86, 0, 255)
createColorSlider("saturation", Color3.fromRGB(220, 220, 220), 124, 0, 1)

local function synchronizeSliderPositions(pData)
	if not pData then return end
	local targets = {colorR = pData.colorR or 255, colorG = pData.colorG or 255, colorB = pData.colorB or 255, saturation = pData.saturation or 1}
	
	for name, val in pairs(targets) do
		local s = sliders[name]
		if s then
			local pct = (val - s.min) / (s.max - s.min)
			s.knob.Position = UDim2.new(pct, -6, 0.5, -6)
			s.label.Text = name .. ": " .. tostring(val)
		end
	end
end

updateEditorUI = function()
	if selectedItemName == "" then
		compSelectBtn.Text = "No Item Selected"
		ColorPanel.Visible = false
		for _, box in pairs(inputs) do box.Text = "" end
		return
	end
	
	compSelectBtn.Text = "Part: " .. selectedSubPartName
	ColorPanel.Visible = true
	compDropdownScroll:ClearAllChildren()
	
	local dropLayout = Instance.new("UIListLayout")
	dropLayout.Parent = compDropdownScroll
	
	local itemProfile = CustomOffsets[selectedTierName][selectedItemName]
	if not itemProfile then return end
	
	local sorted = {}
	for n, _ in pairs(itemProfile) do table.insert(sorted, n) end
	table.sort(sorted, function(a, b) if a == "Handle" then return true elseif b == "Handle" then return false else return a < b end end)
	
	for _, pName in ipairs(sorted) do
		local rBtn = Instance.new("TextButton")
		rBtn.Size = UDim2.new(1, 0, 0, 22)
		rBtn.BackgroundColor3 = (pName == selectedSubPartName) and Color3.fromRGB(0, 120, 60) or Color3.fromRGB(30, 30, 35)
		rBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		rBtn.Text = pName
		rBtn.Font = Enum.Font.Gotham
		rBtn.TextSize = 10
		rBtn.Parent = compDropdownScroll
		
		rBtn.Activated:Connect(function()
			selectedSubPartName = pName
			dropDownWrapper.Visible = false
			updateEditorUI()
			highlightSelectedSubPart()
		end)
	end
	compDropdownScroll.CanvasSize = UDim2.new(0, 0, 0, #sorted * 22)
	
	local pData = itemProfile[selectedSubPartName]
	if pData then
		inputs["offsetX"].Text = tostring(pData.offsetX)
		inputs["offsetY"].Text = tostring(pData.offsetY)
		inputs["offsetZ"].Text = tostring(pData.offsetZ)
		inputs["rotateX"].Text = tostring(pData.rotateX)
		inputs["rotateY"].Text = tostring(pData.rotateY)
		inputs["rotateZ"].Text = tostring(pData.rotateZ)
		inputs["scaleX"].Text  = tostring(pData.scaleX)
		inputs["scaleY"].Text  = tostring(pData.scaleY)
		inputs["scaleZ"].Text  = tostring(pData.scaleZ)
		synchronizeSliderPositions(pData)
	end
end

updateItemUI = function()
	ItemSelectionPanel:ClearAllChildren()
	local listLayout = Instance.new("UIListLayout")
	listLayout.Padding = UDim.new(0, 4)
	listLayout.Parent = ItemSelectionPanel
	
	local targetFolder = TargetPresetFolder:FindFirstChild(selectedTierName)
	if not targetFolder then return end
	
	local children = targetFolder:GetChildren()
	if #children == 0 then
		selectedItemName = ""
		updateEditorUI()
		return
	end
	
	for _, child in ipairs(children) do
		local iBtn = Instance.new("TextButton")
		iBtn.Size = UDim2.new(1, 0, 0, 26)
		iBtn.BackgroundColor3 = (child.Name == selectedItemName) and Color3.fromRGB(0, 90, 160) or Color3.fromRGB(35, 35, 40)
		iBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		iBtn.Text = child.Name
		iBtn.Font = Enum.Font.GothamSemibold
		iBtn.TextSize = 10
		iBtn.Parent = ItemSelectionPanel
		
		iBtn.Activated:Connect(function()
			selectedItemName = child.Name
			selectedSubPartName = "Handle"
			updateItemUI()
			updateEditorUI()
			highlightSelectedSubPart()
		end)
	end
	ItemSelectionPanel.CanvasSize = UDim2.new(0, 0, 0, #children * 30)
end

updateTierUI = function()
	TierSelectionPanel:ClearAllChildren()
	local listLayout = Instance.new("UIListLayout")
	listLayout.Padding = UDim.new(0, 4)
	listLayout.Parent = TierSelectionPanel
	
	local tiers = {Config.SelectedDefault, Config.SelectedMinor, Config.SelectedMedium, Config.SelectedMajor, Config.SelectedCritical}
	for _, tName in ipairs(tiers) do
		local tBtn = Instance.new("TextButton")
		tBtn.Size = UDim2.new(1, 0, 0, 26)
		tBtn.BackgroundColor3 = (tName == selectedTierName) and Color3.fromRGB(120, 80, 0) or Color3.fromRGB(35, 35, 40)
		tBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		tBtn.Text = tName
		tBtn.Font = Enum.Font.GothamBold
		tBtn.TextSize = 10
		tBtn.Parent = TierSelectionPanel
		
		tBtn.Activated:Connect(function()
			selectedTierName = tName
			selectedItemName = ""
			selectedSubPartName = "Handle"
			updateTierUI()
			updateItemUI()
			updateEditorUI()
			clearActiveHighlight()
		end)
	end
	TierSelectionPanel.CanvasSize = UDim2.new(0, 0, 0, #tiers * 30)
end

