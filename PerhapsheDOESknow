local function createMatrixInput(labelText, property, yPos)
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0, 70, 0, 22)
	label.Position = UDim2.new(0, 0, 0, yPos)
	label.BackgroundTransparency = 1
