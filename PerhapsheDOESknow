local function batchRehydrateSavedAssets()
	for tierName, idList in pairs(AssetIdsToLoad) do for _, id in ipairs(idList) do task.spawn(injectAssetId, id, tierName, true) end end
	for tierName, extractionList in pairs(ExtractedNamesToLoad) do for _, name in ipairs(extractionList) do generateExtractedPlaceholderModel(tierName, name) end end
	task.wait(0.2); updateItemUI(); updateEditorUI()
end

