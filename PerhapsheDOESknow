-- ====================================================================
ExtractBtn.Activated:Connect(function()
	local char = LocalPlayer.Character
	if not char then return end
	
	local head = char:FindFirstChild("Head")
	if not head then return end
	
	local targetFolder = TargetPresetFolder:FindFirstChild(selectedTierName)
	if not targetFolder then return end

	local extractedCount = 0
	ExtractBtn.Text = "EXTRACTING..."
	ExtractBtn.BackgroundColor3 = Color3.fromRGB(130, 90, 0)
	
	for _, child in ipairs(char:GetChildren()) do
		if child:IsA("Accessory") and not table.find(activeClientInstances, child) then
			local handle = child:FindFirstChild("Handle") or child:FindFirstChildWhichIsA("BasePart", true)
			if handle and handle:IsA("BasePart") then
				-- FIX: Use a Unique ID to prevent mirroring
				local uniqueInstanceID = child.Name .. "_" .. tostring(tick())
				
				local assetId = 0
				local mesh = handle:FindFirstChildWhichIsA("SpecialMesh")
				if mesh and mesh.MeshId ~= "" then
					local rawId = string.match(mesh.MeshId, "%d+")
					if rawId then assetId = tonumber(rawId) end
				end

				local cloneCopy = child:Clone()
				cloneCopy.Name = uniqueInstanceID
				
				for _, subItem in ipairs(cloneCopy:GetDescendants()) do
					if subItem:IsA("Weld") or subItem:IsA("ManualWeld") or subItem:IsA("WeldConstraint") or subItem:IsA("Attachment") or subItem:IsA("RigidConstraint") then
						subItem:Destroy()
					end
				end
				cloneCopy.Parent = targetFolder
				
				-- Capture visual mapping using the Unique ID
				if not ExtractedVisuals[selectedTierName] then ExtractedVisuals[selectedTierName] = {} end
				ExtractedVisuals[selectedTierName][uniqueInstanceID] = {}
				
				for _, part in ipairs(cloneCopy:GetDescendants()) do
					if part:IsA("BasePart") then
						local pMesh = part:FindFirstChildWhichIsA("SpecialMesh")
						ExtractedVisuals[selectedTierName][uniqueInstanceID][part.Name] = {
							MeshId = pMesh and pMesh.MeshId or "",
							TextureId = pMesh and pMesh.TextureId or "",
							SizeX = part.Size.X, SizeY = part.Size.Y, SizeZ = part.Size.Z
						}
					end
				end
				
				-- Store tracking using the Unique ID
				if not table.find(ExtractedNamesToLoad[selectedTierName], uniqueInstanceID) then
					table.insert(ExtractedNamesToLoad[selectedTierName], uniqueInstanceID)
				end
				
				initializeItemData(selectedTierName, cloneCopy)
				
				-- Offset Calculation
				local relativeCFrame = head.CFrame:ToObjectSpace(handle.CFrame)
				local offsetX, offsetY, offsetZ = relativeCFrame.X, relativeCFrame.Y, relativeCFrame.Z
				local rX, rY, rZ = relativeCFrame:ToEulerAnglesXYZ()
				local rotX, rotY, rotZ = math.deg(rX), math.deg(rY), math.deg(rZ)
				
				local scaleX, scaleY, scaleZ = 1, 1, 1
				if mesh then
					scaleX, scaleY, scaleZ = mesh.Scale.X, mesh.Scale.Y, mesh.Scale.Z
				else
					scaleX, scaleY, scaleZ = handle.Size.X, handle.Size.Y, handle.Size.Z
				end
				
				if CustomOffsets[selectedTierName] and CustomOffsets[selectedTierName][uniqueInstanceID] then
					CustomOffsets[selectedTierName][uniqueInstanceID]["Handle"] = {
						offsetX = offsetX, offsetY = offsetY, offsetZ = offsetZ,
						rotateX = rotX, rotateY = rotY, rotateZ = rotZ,
						scaleX = scaleX, scaleY = scaleY, scaleZ = scaleZ
					}
				end
				extractedCount = extractedCount + 1
			end
		end
	end
	
	saveProfileData()
	updateItemUI()
	updateEditorUI()
	
	if isPreviewingMode then
		runUpdatePreviewCycle()
	elseif LocalPlayer.Character then
		applyPreset(LocalPlayer.Character, lastPreset)
	end
	
	ExtractBtn.Text = "EXTRACTED (" .. tostring(extractedCount) .. ")"
	ExtractBtn.BackgroundColor3 = Color3.fromRGB(0, 130, 70)
	task.wait(1.2)
	ExtractBtn.Text = "EXTRACT ACCESSORIES"
	ExtractBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 150)
end)

