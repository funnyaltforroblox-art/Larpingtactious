		iBtn.Font = Enum.Font.GothamSemibold
		iBtn.TextSize = 10
		iBtn.Activated:Connect(function() selectedItemName = child.Name; selectedSubPartName = "Handle"; updateItemUI(); updateEditorUI(); highlightSelectedSubPart() end)
