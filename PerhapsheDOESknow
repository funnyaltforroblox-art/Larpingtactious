-- ====================================================================
-- LOCAL FILE SYSTEM SAVE / LOAD PIPELINE
-- ====================================================================
local function saveProfileData()
	local success, err = pcall(function()
		if writefile then
			local package = {
				Offsets = CustomOffsets,
				AssetIds = AssetIdsToLoad,
				ExtractedNames = ExtractedNamesToLoad,
				ExtractedVisuals = ExtractedVisuals,
				Slots = SaveSlots,
				SlotNames = SlotNames
			}
			local jsonString = HttpService:JSONEncode(package)
			writefile(FILE_NAME, jsonString)
			print("[FEX Save Engine]: Successfully wrote file to workspace/" .. FILE_NAME)
		else
			warn("[FEX Save Warning]: Your executor does not support 'writefile'!")
		end
	end)
	
	if not success then
		warn("[FEX Save Error]: Executor failed to save file! Reason: " .. tostring(err))
	end
end

local function loadProfileData()
	local success, result = pcall(function()
		if readfile and isfile and isfile(FILE_NAME) then
			return readfile(FILE_NAME)
		end
		return nil
	end)
	
	if success and result and type(result) == "string" then
		local successParse, parsedData = pcall(function()
			return HttpService:JSONDecode(result)
		end)
		if successParse and type(parsedData) == "table" then
			CustomOffsets = parsedData.Offsets or {}
			AssetIdsToLoad = parsedData.AssetIds or {}
			ExtractedNamesToLoad = parsedData.ExtractedNames or {}
			ExtractedVisuals = parsedData.ExtractedVisuals or {}
			SaveSlots = parsedData.Slots or {}
			SlotNames = parsedData.SlotNames or {}
			print("[FEX Local Engine]: Successfully loaded presets and slots from workspace/" .. FILE_NAME)
			return
		end
	end
	print("[FEX Local Engine]: No local file found or fresh setup. Creating clean profile matrix.")
end

