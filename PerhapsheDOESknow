local function clearActiveHighlight()
	if currentHighlightBox then
		currentHighlightBox:Destroy()
		currentHighlightBox = nil
	end
end

local function highlightSelectedSubPart()
	clearActiveHighlight()
	local character = LocalPlayer.Character
	if not character or selectedItemName == "" then return end
	
	for _, inst in ipairs(activeClientInstances) do
		if inst and inst.Parent and inst.Name == selectedItemName then
			local targetPartInstance = (inst:IsA("BasePart") and inst.Name == selectedSubPartName) and inst or inst:FindFirstChild(selectedSubPartName, true)
			if not targetPartInstance then
				for _, d in ipairs(inst:GetDescendants()) do
					if d:IsA("BasePart") and d.Name == selectedSubPartName then
						targetPartInstance = d
						break
					end
				end
			end
			
			if targetPartInstance and targetPartInstance:IsA("BasePart") then
				local selectionBox = Instance.new("SelectionBox")
				selectionBox.Name = "Customizer_PartHighlight"
				selectionBox.Color3 = Color3.fromRGB(0, 255, 255)
				selectionBox.LineThickness = 0.04
				selectionBox.Adornee = targetPartInstance
				selectionBox.Parent = targetPartInstance
				currentHighlightBox = selectionBox
				break
			end
		end
	end
end

-- ====================================================================
-- COLOR PROJECTION UTILITY
-- ====================================================================
local function applyColorTransform(part, pData)
	if not pData then return end
	local baseColor = Color3.fromRGB(pData.colorR or 255, pData.colorG or 255, pData.colorB or 255)
	
	if pData.saturation and pData.saturation < 1 then
		local h, s, v = baseColor:ToHSV()
		baseColor = Color3.fromHSV(h, s * pData.saturation, v)
	end
	
	part.Color = baseColor
	local mesh = part:FindFirstChildWhichIsA("SpecialMesh")
	if mesh then
		mesh.VertexColor = Vector3.new(baseColor.R, baseColor.G, baseColor.B)
	end
end

-- ====================================================================
-- COUPLING MECHANICAL RE-WELD PIPELINE
-- ====================================================================
local function localAttach(character, tierName, item)
	local head = character:WaitForChild("Head", 5)
	if not head then return end
	
	initializeItemData(tierName, item)
	local itemData = CustomOffsets[tierName][item.Name]
	
	local clone = item:Clone()
	local handle = clone.Name == "Handle" and clone or clone:FindFirstChild("Handle") or clone:FindFirstChildWhichIsA("BasePart", true)
	if not handle and clone:IsA("Model") and clone.PrimaryPart then handle = clone.PrimaryPart end
	if not handle then return end
	
	handle.Name = "Handle"
	
	for _, child in ipairs(clone:GetDescendants()) do
		if child:IsA("Weld") or child:IsA("ManualWeld") or child:IsA("WeldConstraint") or child:IsA("Attachment") then
			child:Destroy()
		end
	end
	
	local structuralOffsets = {}
	local partCounter = 1
	
	for _, obj in ipairs(clone:GetDescendants()) do
		if obj:IsA("BasePart") and obj ~= handle then
			if obj.Name == "Part" or obj.Name == "MeshPart" or obj.Name == "" then
				obj.Name = "Component_" .. tostring(partCounter)
				partCounter = partCounter + 1
			end
			
			structuralOffsets[obj.Name] = handle.CFrame:ToObjectSpace(obj.CFrame)
			obj.Anchored = false; obj.CanCollide = false; obj.Massless = true
			
			local pData = itemData[obj.Name]
			if pData then
				local mesh = obj:FindFirstChildWhichIsA("SpecialMesh")
				if mesh then
					mesh.Scale = Vector3.new(pData.scaleX, pData.scaleY, pData.scaleZ)
				else
					obj.Size = Vector3.new(pData.scaleX, pData.scaleY, pData.scaleZ)
				end
				applyColorTransform(obj, pData)
			end
		end
	end
	
	handle.Anchored = false; handle.CanCollide = false; handle.Massless = true
	local rootData = itemData["Handle"] or {offsetX=0,offsetY=0,offsetZ=0,rotateX=0,rotateY=0,rotateZ=0,scaleX=1,scaleY=1,scaleZ=1,colorR=255,colorG=255,colorB=255,saturation=1}
	local rootMesh = handle:FindFirstChildWhichIsA("SpecialMesh")
	if rootMesh then
		rootMesh.Scale = Vector3.new(rootData.scaleX, rootData.scaleY, rootData.scaleZ)
	else
		handle.Size = Vector3.new(rootData.scaleX, rootData.scaleY, rootData.scaleZ)
	end
	applyColorTransform(handle, rootData)

	for _, obj in ipairs(clone:GetDescendants()) do
		if obj:IsA("BasePart") and obj ~= handle then
			local pData = itemData[obj.Name] or {offsetX=0,offsetY=0,offsetZ=0,rotateX=0,rotateY=0,rotateZ=0}
			local innerWeld = Instance.new("Weld")
			innerWeld.Name = "ModelInnerWeld"
			innerWeld.Part0 = obj; innerWeld.Part1 = handle
			
			local originalLocalCFrame = structuralOffsets[obj.Name] or CFrame.new()
			local customPosOffset = CFrame.new(pData.offsetX, pData.offsetY, pData.offsetZ)
			local customRotOffset = CFrame.Angles(math.rad(pData.rotateX), math.rad(pData.rotateY), math.rad(pData.rotateZ))
			
			innerWeld.C0 = originalLocalCFrame:Inverse() * (customPosOffset * customRotOffset)
			innerWeld.Parent = obj
		end
	end

	local accessory = clone:IsA("Accessory") and clone or Instance.new("Accessory")
	if not clone:IsA("Accessory") then
		accessory.Name = item.Name
		clone.Parent = accessory
	else
		accessory.Name = item.Name
	end
	
	local rootWeld = Instance.new("Weld")
	rootWeld.Name = "AccessoryWeld"
	rootWeld.Part0 = handle; rootWeld.Part1 = head
	
	local positionOffset = CFrame.new(rootData.offsetX, rootData.offsetY, rootData.offsetZ)
	local rotationOffset = CFrame.Angles(math.rad(rootData.rotateX), math.rad(rootData.rotateY), math.rad(rootData.rotateZ))
	
	rootWeld.C0 = positionOffset * rotationOffset
	rootWeld.Parent = handle
	
	accessory.Parent = character
	table.insert(activeClientInstances, accessory)
end

local function clearActiveItems()
	clearActiveHighlight()
	for _, item in ipairs(activeClientInstances) do
		if item and item.Parent then item:Destroy() end
	end
	activeClientInstances = {}
end

local function applyPreset(character, folderName)
	clearActiveItems()
	if folderName == "" or folderName == "None" then return end
	
	local folder = TargetPresetFolder:FindFirstChild(folderName)
	if not folder then return end
	
	for _, item in ipairs(folder:GetChildren()) do
		task.spawn(localAttach, character, folderName, item)
	end
	task.defer(highlightSelectedSubPart)
end

local function monitorHealth(character)
	local humanoid = character:WaitForChild("Humanoid")
	
	local function check()
		local ratio = humanoid.Health / humanoid.MaxHealth
		local target = Config.SelectedDefault
		
		if ratio <= 0.15 then target = Config.SelectedCritical
		elseif ratio <= 0.30 then target = Config.SelectedMajor
		elseif ratio <= 0.50 then target = Config.SelectedMedium
		elseif ratio <= 0.75 then target = Config.SelectedMinor end
		
		if target ~= lastPreset then
			lastPreset = target
			applyPreset(character, target)
		end
	end
	
	humanoid.HealthChanged:Connect(check)
	check()
end

