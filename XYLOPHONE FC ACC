-- Using FindFirstChild to prevent infinite freezing/hanging
local TargetPresetFolder = ReplicatedStorage:FindFirstChild("FaceAccPresets")
if not TargetPresetFolder then
	local success, result = pcall(function()
		local folder = Instance.new("Folder")
		folder.Name = "FaceAccPresets"
		folder.Parent = ReplicatedStorage
		return folder
	end)
	if success then
		TargetPresetFolder = result
	else
		-- Absolute fallback if ReplicatedStorage is completely locked down by game core
		TargetPresetFolder = Instance.new("Folder")
		TargetPresetFolder.Name = "FaceAccPresets"
		TargetPresetFolder.Parent = LocalPlayer:WaitForChild("PlayerGui")
		print("[FEX Warning] ReplicatedStorage locked. Folders created in PlayerGui instead.")
	end
end

local function ensureSubFolder(name)
	if not TargetPresetFolder:FindFirstChild(name) then
		local subFolder = Instance.new("Folder")
		subFolder.Name = name
		subFolder.Parent = TargetPresetFolder
	end
end

ensureSubFolder("face acc")
ensureSubFolder("MinorDamage")
ensureSubFolder("MediumDamage")
ensureSubFolder("MajorDamage")
ensureSubFolder("CriticalDamage")

local Config = {
	SelectedDefault  = "face acc",
	SelectedMinor    = "MinorDamage",
	SelectedMedium   = "MediumDamage",
	SelectedMajor    = "MajorDamage",
	SelectedCritical = "CriticalDamage"
}

local lastPreset = ""
local activeClientInstances = {}

-- ====================================================================
-- CORE ATTACHMENT / CLEANUP ENGINE
-- ====================================================================

local function registerPreset(tier, newFolderName)
	ensureSubFolder(newFolderName)
	if tier == "Default" then Config.SelectedDefault = newFolderName
	elseif tier == "Minor" then Config.SelectedMinor = newFolderName
	elseif tier == "Medium" then Config.SelectedMedium = newFolderName
	elseif tier == "Major" then Config.SelectedMajor = newFolderName
	elseif tier == "Critical" then Config.SelectedCritical = newFolderName end
	
	lastPreset = "" 
	if LocalPlayer.Character then
		local human = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
		if human then human.Health = human.Health end
	end
end

local function clearActiveItems()
	for _, item in ipairs(activeClientInstances) do
		if item and item.Parent then item:Destroy() end
	end
	activeClientInstances = {}
end

local function localAttach(character, item)
	local head = character:WaitForChild("Head", 5)
	if not head then return end
	local clone = item:Clone()
	
	if clone:IsA("Accessory") then
		local handle = clone:FindFirstChild("Handle")
		if handle and handle:IsA("BasePart") then
			local accAttachment = handle:FindFirstChildOfClass("Attachment")
			if accAttachment then
				local charAttachment = character:FindFirstChild(accAttachment.Name, true)
				if charAttachment and charAttachment:IsA("Attachment") then
					handle.CFrame = charAttachment.WorldCFrame * accAttachment.CFrame:Inverse()
					local weld = Instance.new("Weld")
					weld.Part0 = handle; weld.Part1 = charAttachment.Parent
					weld.C0 = accAttachment.CFrame; weld.C1 = charAttachment.CFrame
					weld.Parent = handle
				end
			else
				handle.CFrame = head.CFrame
				local weld = Instance.new("WeldConstraint")
				weld.Part0 = handle; weld.Part1 = head; weld.Parent = handle
			end
			clone.Parent = character
			table.insert(activeClientInstances, clone)
		end
	elseif clone:IsA("Model") then
		local primary = clone.PrimaryPart or clone:FindFirstChildWhichIsA("BasePart", true)
		if primary then
			clone:SetPrimaryPartCFrame(head.CFrame)
			local weld = Instance.new("WeldConstraint")
			weld.Part0 = primary; weld.Part1 = head; weld.Parent = primary
			for _, part in ipairs(clone:GetDescendants()) do
				if part:IsA("BasePart") and part ~= primary then
					local innerWeld = Instance.new("WeldConstraint")
					innerWeld.Part0 = part; innerWeld.Part1 = primary; innerWeld.Parent = part
					part.CanCollide = false
				end
			end
			clone.Parent = character
			table.insert(activeClientInstances, clone)
		end
	elseif clone:IsA("BasePart") or clone:IsA("MeshPart") then
		clone.CFrame = head.CFrame
		clone.CanCollide = false; clone.Massless = true
		local weld = Instance.new("WeldConstraint")
		weld.Part0 = clone; weld.Part1 = head; weld.Parent = clone
		clone.Parent = character
		table.insert(activeClientInstances, clone)
	end
end

local function stripGameFaceAccessories(character)
	for _, child in ipairs(character:GetChildren()) do
		if child:IsA("Accessory") then
			local handle = child:FindFirstChild("Handle")
			if handle then
				local attachment = handle:FindFirstChildOfClass("Attachment")
				if attachment and string.find(attachment.Name, "Face") then
					child:Destroy()
				end
			end
		end
	end
end

local function applyPreset(character, folderName)
	clearActiveItems()
	if folderName == "" or folderName == "None" then return end
	
	stripGameFaceAccessories(character)
	local folder = TargetPresetFolder:FindFirstChild(folderName)
	if not folder then return end
	
	for _, item in ipairs(folder:GetChildren()) do
		task.spawn(localAttach, character, item)
	end
end

local function monitorHealth(character)
	local human = character:WaitForChild("Humanoid")
	
	local function check()
		local ratio = human.Health / human.MaxHealth
		local target = Config.SelectedDefault
		
		if ratio <= 0.15 then
			target = Config.SelectedCritical
		elseif ratio <= 0.30 then
			target = Config.SelectedMajor
		elseif ratio <= 0.50 then
			target = Config.SelectedMedium
		elseif ratio <= 0.75 then
			target = Config.SelectedMinor
		end
		
		if target ~= lastPreset then
			lastPreset = target
			applyPreset(character, target)
		end
	end
	
	human.HealthChanged:Connect(check)
	check()
end

